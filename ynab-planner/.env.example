# YNAB Budget Planner — environment configuration.
# Copy this to `.env` (which is git-ignored) and fill it in.
# Real environment variables take precedence over values in `.env`.

# Read-only YNAB Personal Access Token.
# Create one at https://app.ynab.com/settings/developer ("New Token").
# Required only to sync (read) your budget from YNAB.
YNAB_TOKEN=

# Optional: directory where plan.edn / cache.edn are stored (default: current directory).
# YP_DATA_DIR=.

# Optional: plan a specific month as YYYY-MM (default: current month).
# YP_PLAN_MONTH=2026-07

# Note: the YNAB budget id is NOT set here — it lives in plan.edn under :budget-id
# (the alias "last-used" works), since the rest of your plan lives there too.
